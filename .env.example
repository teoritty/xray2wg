# ── Required ──────────────────────────────────────────────────────────────────
# Exact browser origins allowed for CORS and WebSocket.
# Use your server's LAN IP or domain. No trailing slash.
CORS_ALLOWED_ORIGINS=https://192.168.1.100:8080

# ── Network ───────────────────────────────────────────────────────────────────
# Listen port for the web server (HTTPS by default).
PORT=8080

# Server IP/hostname used in WireGuard peer .conf exports.
# Leave empty to auto-detect from network interfaces.
# PUBLIC_HOST=192.168.1.100

# ── TLS ───────────────────────────────────────────────────────────────────────
# Disable TLS and use plain HTTP (development only).
TLS_OFF=false

# Auto-generate a self-signed certificate if TLS_CERT_FILE / TLS_KEY_FILE are missing.
TLS_AUTO_CERT=true

# Path to your own certificate and key (skips auto-generation when both are set).
# TLS_CERT_FILE=/data/tls/cert.pem
# TLS_KEY_FILE=/data/tls/key.pem

# Optional: bind address for HTTP→HTTPS redirect server.
# HTTP_REDIRECT_ADDR=:80

# Set to true when xray2wg sits behind a TLS-terminating reverse proxy.
BEHIND_HTTPS=false

# ── Data ──────────────────────────────────────────────────────────────────────
# Directory for SQLite DB, master key, JWT key, and TLS material.
DATA_DIR=/data

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# xray-core log level: debug | info | warning | error | none
XRAY_LOG_LEVEL=warning

# Verbose tunnel lifecycle logs (grep "tunnel_trace"). Disable when stable.
# XRAY2WG_TUNNEL_TRACE=1

# ── Metrics ───────────────────────────────────────────────────────────────────
# If set, GET /metrics requires header "X-Metrics-Key: <value>".
# If unset, /metrics is only accessible from loopback (127.0.0.1/::1).
# METRICS_API_KEY=your-secret-key
